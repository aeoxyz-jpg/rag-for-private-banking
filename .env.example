# Copy to .env and edit as needed. All values have sensible local-first defaults.

# --- model roles (hybrid stack) ---
# OLLAMA_HOST=http://127.0.0.1:11434
# RM_FAST_LLM=qwen2.5:3b-instruct
# RM_SMART_PROVIDER=codex            # codex | anthropic | ollama
# RM_SMART_MODEL=                    # provider-specific; blank = provider default
# RM_EMBED_MODEL=bge-m3:latest
# ANTHROPIC_API_KEY=                 # only if RM_SMART_PROVIDER=anthropic

# --- Berka source (CTU public read-only DB; override only if mirroring) ---
# BERKA_HOST=relational.fel.cvut.cz
# BERKA_USER=guest
# BERKA_PASSWORD=ctu-relational
# BERKA_DB=financial
